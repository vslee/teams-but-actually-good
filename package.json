{
  "name": "teams-but-good",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "author": "LeonimusT",
  "scripts": {
    "generate:plugins": "bun run scripts/generate-plugins.ts",
    "build": "bun run generate:plugins && bun esbuild src/injection.ts --bundle --loader:.css=text --outfile=dist/injection.js && cp dist/injection.js extension/injection.js",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "dev": "bun run build && bun run tauri:dev",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "eslint": "^10.0.1",
    "react-devtools-core": "^7.0.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.2.14",
    "esbuild": "^0.27.3",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}