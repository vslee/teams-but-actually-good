{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "remote": {
    "urls": [
      "https://teams.cloud.microsoft/*",
      "https://teams.microsoft.com/*"
    ]
  },
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "opener:default"
  ]
}