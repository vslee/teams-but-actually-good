{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "teams-but-actually-good",
  "version": "0.1.0",
  "identifier": "com.leonimust.teams-but-actually-good",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "macOS": {
      "hardenedRuntime": true
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "$TAURI_UPDATER_PUBLIC_KEY",
      "endpoints": [
        "https://github.com/LeonimusTTV/teams-but-actually-good/releases/latest/download/latest.json"
      ]
    }
  }
}