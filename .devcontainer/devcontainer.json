{
  "name": "Teams but (actually) good",
  "image": "mcr.microsoft.com/devcontainers/typescript-node",
  "features": {
    "ghcr.io/shyim/devcontainers-features/bun": {},
    "ghcr.io/devcontainers/features/rust": {},
    "ghcr.io/olivierlemasle/devcontainers-features/tauri": {},
    "ghcr.io/devcontainers/features/github-cli": {},
    "ghcr.io/devcontainers/features/desktop-lite": {}
  },
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb"
  },
  "postCreateCommand": "sudo chown -R $(id -u):$(id -g) /usr/local/cargo/registry ${containerWorkspaceFolder}/src-tauri/target && sudo apt-get update && sudo apt-get install -y gdb && bun install && bun run generate",
  "mounts": [
    {
      "type": "volume",
      "source": "teams-but-good-cargo-registry",
      "target": "/usr/local/cargo/registry"
    },
    {
      "type": "volume",
      "source": "teams-but-good-tauri-target",
      "target": "${containerWorkspaceFolder}/src-tauri/target"
    }
  ],
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "Tauri App (noVNC desktop)",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "eslint.workingDirectories": ["."]
      },
      "extensions": [
        "oven.bun-vscode",
        "rust-lang.rust-analyzer",
        "tauri-apps.tauri-vscode",
        "dbaeumer.vscode-eslint",
        "vadimcn.vscode-lldb",
        "ms-vscode.cpptools"
      ]
    }
  }
}
