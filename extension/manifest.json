{
  "manifest_version": 3,
  "name": "Teams But (actually) Good",
  "version": "0.1.0",
  "description": "A Microsoft Teams extension that actually improves the user experience.",
  "author": "LeonimusT",
  "permissions": [
    "alarms",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://teams.microsoft.com/*",
    "*://*.teams.microsoft.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Teams But Good"
  },
  "background": {
    "service_worker": "background.js"
  }
}