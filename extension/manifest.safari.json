{
  "manifest_version": 3,
  "name": "Teams but (actually) good",
  "version": "0.0.1",
  "description": "A Microsoft Teams extension that actually improves the user experience.",
  "author": "LeonimusT",
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://github.com/*",
    "*://teams.microsoft.com/*",
    "*://*.teams.microsoft.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Teams but (actually) good",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "96": "icons/icon96.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}