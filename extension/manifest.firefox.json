{
  "manifest_version": 3,
  "name": "Teams But (actually) Good",
  "version": "0.1.0",
  "description": "A Microsoft Teams extension that actually improves the user experience.",
  "author": "LeonimusT",
  "browser_specific_settings": {
    "gecko": {
      "id": "teams-but-good@leonimust",
      "strict_min_version": "128.0"
    }
  },
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://teams.microsoft.com/*",
    "*://*.teams.microsoft.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Teams But Good"
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  }
}