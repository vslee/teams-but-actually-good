{
  "manifest_version": 3,
  "name": "Teams but (actually) good",
  "version": "0.4.1",
  "description": "A Microsoft Teams extension that actually improves the user experience.",
  "author": "LeonimusT",
  "browser_specific_settings": {
    "gecko": {
      "id": "teams-but-good@leonimust",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "permissions": [
    "alarms",
    "storage",
    "scripting",
    "cookies",
    "tabs"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*",
    "https://release-assets.githubusercontent.com/*",
    "*://teams.microsoft.com/*",
    "*://*.teams.microsoft.com/*",
    "ws://localhost/*",
    "ws://127.0.0.1/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Teams but (actually) good",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "96": "icons/icon96.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  }
}